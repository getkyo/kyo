{
  "$schema": "https://anthropic.com/claude-code/marketplace.schema.json",
  "name": "kyo-local",
  "description": "Local marketplace for kyo demo LSP servers. Launches each demo through proxy.py so the JVM can be hot-reloaded by touching .mcp-validation/reload.sentinel without disconnecting Claude Code.",
  "owner": {
    "name": "kyo",
    "email": "fwbrasil@gmail.com"
  },
  "plugins": [
    {
      "name": "kyo-todo-lsp",
      "description": "kyo-lsp TodoLsp demo: hover + completion for .todo files (TODO/DONE/WAIT keywords).",
      "version": "0.1.0",
      "author": {
        "name": "kyo",
        "email": "fwbrasil@gmail.com"
      },
      "source": "./plugins/kyo-todo-lsp",
      "category": "development",
      "strict": false,
      "lspServers": {
        "kyo-todo-lsp": {
          "command": "/Users/fwbrasil/workspace/kyo/.claude/worktrees/crispy-swinging-lemur/.mcp-validation/proxy.py",
          "args": [
            "content-length",
            "kyo-lsp",
            "demo.TodoLsp"
          ],
          "extensionToLanguage": {
            ".todo": "todo"
          }
        }
      }
    },
    {
      "name": "kyo-todo-diagnostics-lsp",
      "description": "kyo-lsp TodoDiagnostics demo: publishes diagnostics (duplicate/unknown-keyword/empty-body) and serves documentSymbol outline for .todo-diag files.",
      "version": "0.1.0",
      "author": {
        "name": "kyo",
        "email": "fwbrasil@gmail.com"
      },
      "source": "./plugins/kyo-todo-diagnostics-lsp",
      "category": "development",
      "strict": false,
      "lspServers": {
        "kyo-todo-diagnostics-lsp": {
          "command": "/Users/fwbrasil/workspace/kyo/.claude/worktrees/crispy-swinging-lemur/.mcp-validation/proxy.py",
          "args": [
            "content-length",
            "kyo-lsp",
            "demo.TodoDiagnostics"
          ],
          "extensionToLanguage": {
            ".todo-diag": "todo"
          }
        }
      }
    }
  ]
}
